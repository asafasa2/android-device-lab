# /etc/systemd/system/adb-lab.service
# Generated by Ansible — do not edit manually; re-run the playbook to update.

[Unit]
Description=Android Device Lab
After=network.target
Documentation=file://{{ adb_lab_dest }}/README.md

[Service]
Type=simple
User={{ adb_lab_user }}
Group={{ adb_lab_user }}
WorkingDirectory={{ adb_lab_dest }}

ExecStart={{ adb_lab_dest }}/venv/bin/uvicorn backend.main:app \
    --host 0.0.0.0 \
    --port {{ adb_lab_web_port }} \
    --log-level info

Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=adb-lab

Environment="ADB_LAB_PASSWORD={{ adb_lab_password }}"
Environment="ADB_LAB_PORT={{ adb_lab_web_port }}"
Environment="ADB_PATH=adb"
Environment="RESERVATION_TIMEOUT_HOURS={{ adb_lab_reservation_timeout_hours }}"
Environment="DEVICE_POLL_INTERVAL={{ adb_lab_device_poll_interval }}"
Environment="ADB_LAB_CI_API_KEY={{ adb_lab_ci_api_key }}"

SupplementaryGroups=plugdev

[Install]
WantedBy=multi-user.target
